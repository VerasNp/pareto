root = true

# -------------------------
# Default (TypeScript / JS)
# -------------------------
[*]
indent_style = tab
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# -------------------------
# JSON (always spaces)
# -------------------------
[*.json]
indent_style = space
indent_size = 2
